def load_config(path: Path) -> dict:
if not path.exists():
logging.error(f"Config not found: {path}")
print(f"ERR: config not found: {path}", file=sys.stderr)
sys.exit(2)

with open(path, "r", encoding="utf-8") as f:
return json.load(f)


def save_config(path: Path, config: dict) -> None:
with open(path, "w", encoding="utf-8") as f:
json.dump(config, f, indent=2, ensure_ascii=False)


def fetch_districts(domain, listing_path, city):

# OLX UA API mode
if "olx.ua" in domain:

url = f"https://{domain}/api/v1/geo-encoder/location-autocomplete/?query={city}"

logging.info(f"Fetching districts API for {city}")

response = requests.get(url, headers=HEADERS, timeout=20)

if response.status_code != 200:
logging.warning(f"{city} API status {response.status_code}")
return {}

data = response.json()

districts = {}

for item in data.get("data", []):
district = item.get("district")

if district:
name = district["name"].strip()
did = int(district["id"])
districts[name] = did

logging.info(f"{city} districts found: {len(districts)}")

return districts


# OLX PL fallback scraping mode

url = f"https://{domain}{listing_path.format(city=city)}"

logging.info(f"Fetching districts for {city}: {url}")

response = requests.get(url, headers=HEADERS, timeout=20)

if response.status_code != 200:
return {}

html = response.text

matches = re.findall(
r'search%5Bdistrict_id%5D=(\d+)".*?>([^<]+)',
html,
re.DOTALL,
)



